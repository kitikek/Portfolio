{
  "info": {
    "_postman_id": "portfolio-tests",
    "name": "Portfolio API Tests",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "POST /api/v1/portfolios - Create portfolio",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 201\", function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "pm.test(\"Response has success true and data with id\", function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData.success).to.be.true;",
              "    pm.expect(jsonData.data).to.have.property('id');",
              "    pm.environment.set(\"portfolioId\", jsonData.data.id);",
              "});",
              "pm.test(\"Title matches\", function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData.data.title).to.eql(\"Test Portfolio\");",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"userId\": 1,\n    \"title\": \"Test Portfolio\",\n    \"description\": \"This is a test portfolio\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/portfolios",
          "host": [ "{{base_url}}" ],
          "path": [ "api", "v1", "portfolios" ]
        }
      },
      "response": []
    },
    {
      "name": "GET /api/v1/users/1/portfolios - Get portfolios by user",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test(\"Response has success true and data array\", function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData.success).to.be.true;",
              "    pm.expect(jsonData.data).to.be.an('array');",
              "});",
              "pm.test(\"The array contains the created portfolio\", function () {",
              "    const jsonData = pm.response.json();",
              "    const portfolioId = pm.environment.get(\"portfolioId\");",
              "    const found = jsonData.data.find(p => p.id == portfolioId);",
              "    pm.expect(found).to.exist;",
              "    pm.expect(found.title).to.eql(\"Test Portfolio\");",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/v1/users/1/portfolios",
          "host": [ "{{base_url}}" ],
          "path": [ "api", "v1", "users", "1", "portfolios" ]
        }
      },
      "response": []
    },
    {
      "name": "PUT /api/v1/portfolios/:id/publish - Publish portfolio",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test(\"Response has success true and message\", function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData.success).to.be.true;",
              "    pm.expect(jsonData.message).to.include(\"published\");",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "PUT",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/v1/portfolios/{{portfolioId}}/publish",
          "host": [ "{{base_url}}" ],
          "path": [ "api", "v1", "portfolios", "{{portfolioId}}", "publish" ]
        }
      },
      "response": []
    },
    {
      "name": "GET /api/v1/users/1/portfolios - Verify published status",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test(\"Portfolio is now public\", function () {",
              "    const jsonData = pm.response.json();",
              "    const portfolioId = pm.environment.get(\"portfolioId\");",
              "    const portfolio = jsonData.data.find(p => p.id == portfolioId);",
              "    pm.expect(portfolio).to.exist;",
              "    pm.expect(portfolio.isPublic).to.equal(1);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/v1/users/1/portfolios",
          "host": [ "{{base_url}}" ],
          "path": [ "api", "v1", "users", "1", "portfolios" ]
        }
      },
      "response": []
    }
  ]
}